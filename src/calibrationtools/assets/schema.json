{
    "$id": "https://github.com/CDCGov/cfa-calibration-tools/src/assets/schema.json",
    "type": "object",
    "properties": {
        "priors": {
            "type": "object",
            "additionalProperties": {
                "$ref": "#/$defs/parameter_prior"
            }
        }
    },
    "required": ["priors"],
    "$defs": {
        "parameter_prior": {
            "type": "object",
            "properties": {
                "distribution": {
                    "enum": ["uniform", "normal", "lognormal", "exponential", "gamma", "beta"]
                },
                "parameters": {"type": "object"}
            },
            "allOf": [
                {"$ref": "#/$defs/uniform_distribution"},
                {"$ref": "#/$defs/normal_distribution"},
                {"$ref": "#/$defs/lognormal_distribution"},
                {"$ref": "#/$defs/exponential_distribution"},
                {"$ref": "#/$defs/gamma_distribution"},
                {"$ref": "#/$defs/beta_distribution"}
            ],
            "required": ["distribution", "parameters"],
            "additionalProperties": false
        },
        "uniform_distribution": {
            "if": {
                "properties": {
                    "distribution": {"const": "uniform"}
                }
            },
            "then": {
                "properties": {
                    "parameters": {
                        "type": "object",
                        "properties": {
                            "min": {"type": "number"},
                            "max": {"type": "number"}
                        },
                        "required": ["min", "max"],
                        "additionalProperties": false
                    }
                }
            }
        },
        "normal_distribution": {
            "if": {
                "properties": {
                    "distribution": {"const": "normal"}
                }
            },
            "then": {
                "properties": {
                    "parameters": {
                        "type": "object",
                        "properties": {
                            "mean": {"type": "number"},
                            "std_dev": {"type": "number", "exclusiveMinimum": 0}
                        },
                        "required": ["mean", "std_dev"],
                        "additionalProperties": false
                    }
                }
            }
        },
        "lognormal_distribution": {
            "if": {
                "properties": {
                    "distribution": {"const": "lognormal"}
                }
            },
            "then": {
                "properties": {
                    "parameters": {
                        "type": "object",
                        "properties": {
                            "mean": {"type": "number"},
                            "std_dev": {"type": "number", "exclusiveMinimum": 0}
                        },
                        "required": ["mean", "std_dev"],
                        "additionalProperties": false
                    }
                }
            }
        },
        "exponential_distribution": {
            "if": {
                "properties": {
                    "distribution": {"const": "exponential"}
                }
            },
            "then": {
                "properties": {
                    "parameters": {
                        "type": "object",
                        "properties": {
                            "rate": {"type": "number", "exclusiveMinimum": 0}
                        },
                        "required": ["rate"],
                        "additionalProperties": false
                    }
                }
            }
        },
        "gamma_distribution": {
            "if": {
                "properties": {
                    "distribution": {"const": "gamma"}
                }
            },
            "then": {
                "properties": {
                    "parameters": {
                        "type": "object",
                        "properties": {
                            "shape": {"type": "number", "exclusiveMinimum": 0},
                            "scale": {"type": "number", "exclusiveMinimum": 0}
                        },
                        "required": ["shape", "scale"],
                        "additionalProperties": false
                    }
                }
            }
        },
        "beta_distribution": {
            "if": {
                "properties": {
                    "distribution": {"const": "beta"}
                }
            },
            "then": {
                "properties": {
                    "parameters": {
                        "type": "object",
                        "properties": {
                            "alpha": {"type": "number", "exclusiveMinimum": 0},
                            "beta": {"type": "number", "exclusiveMinimum": 0}
                        },
                        "required": ["alpha", "beta"],
                        "additionalProperties": false
                    }
                }
            }
        }
    }
}
